# reCAPTCHA v2 — site key pública, registrada en Google reCAPTCHA Admin Console para
# el dominio de producción. La usada por defecto en Recaptcha.jsx es la clave de
# pruebas de Google (siempre "pasa"): reemplazar antes de lanzar (checklist sección 17).
VITE_RECAPTCHA_SITE_KEY=

# Endpoint de Formspree (https://formspree.io/f/XXXXXXX) para el formulario de contacto.
# Formspree valida el token de reCAPTCHA server-side cuando la integración está activada
# en su dashboard — no basta con validar solo en el cliente (sección 12).
VITE_FORMSPREE_ENDPOINT=
